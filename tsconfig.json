{
  "compilerOptions": {
    "target": "es2024",
    "strict": true,
    "noEmit": true,
    "sourceMap": true,
    "module": "nodenext",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "isolatedModules": true
  },
  "include": ["**/*", ".jest/**/*"],
  "exclude": ["node_modules"]
}
