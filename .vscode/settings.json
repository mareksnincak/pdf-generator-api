{
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "cSpell.words": [
    "aaronshaf",
    "asteasolutions",
    "Ciphertext",
    "dtos",
    "dynamodblocal",
    "EICAR",
    "healthcheck",
    "linebreak",
    "metafile",
    "nodenext",
    "numpages",
    "numrender",
    "nvmrc",
    "openapi",
    "paren",
    "pino",
    "presigner",
    "presynth",
    "Pulumi",
    "signin",
    "singleline",
    "sparticuz",
    "stepfunctions",
    "tfstate",
    "unmarshall"
  ],
  "jestrunner.configPath": ".jest/jest.common.config.ts",
  "jestrunner.runOptions": ["--runInBand"],
  "jestrunner.enableESM": true,
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "never",
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll": "never",
      "source.fixAll.eslint": "explicit"
    }
  }
}
